# Copie este arquivo para .env apenas no seu ambiente local ou na hospedagem.
# Nunca suba o arquivo .env real para o GitHub.

# Banco local com SQLite. Em producao, esta URL pode ser trocada por PostgreSQL/MySQL.
DATABASE_URL=sqlite:///./helpweb_health_local.db

# Gere uma chave longa e aleatoria para producao.
SECRET_KEY=exemplo_troque_por_uma_chave_longa_e_secreta

# Usuario administrador criado automaticamente na primeira execucao.
ADMIN_EMAIL=admin.exemplo@helpwebhealth.local
ADMIN_PASSWORD=troque_esta_senha_antes_de_publicar

# URLs exatas do frontend autorizadas a acessar a API.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://seu-front.shardweb.app
ENABLE_API_DOCS=false
ENABLE_DB_HEALTH_ENDPOINT=false
API_DOCS_USERNAME=admin
API_DOCS_PASSWORD=

# Logs. Use LOG_FORMAT=json se quiser enviar para monitoramento externo.
LOG_LEVEL=INFO
LOG_FORMAT=text
ALLOW_LOG_VERIFICATION_CODES=false

# Email para codigos de verificacao.
# Use dados reais apenas no painel da hospedagem ou no .env local.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=nao-responda@exemplo.com
MAIL_FROM_NAME=HelpWeb Health
REPLY_TO_EMAIL=suporte@exemplo.com
EMAIL_CODE_EXPIRE_MINUTES=15
VERIFICATION_RESEND_COOLDOWN_SECONDS=300

# Rate limit global por IP + usuario/token.
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=240
RATE_LIMIT_SENSITIVE_MAX_REQUESTS=40
