# Copie este arquivo para .env apenas no seu ambiente local ou na hospedagem.
# Nunca suba o arquivo .env real para o GitHub.

# Banco local com SQLite.
DATABASE_URL=sqlite:///./helpweb_health_local.db
# Banco PostgreSQL na hospedagem. Use a URL real somente nas variaveis da Shard.
# Exemplo:
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco?sslmode=require
# URLs fornecidas como postgres://...?...ssl=true tambem sao aceitas e normalizadas.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# Gere uma chave longa e aleatoria para producao, com pelo menos 32 caracteres.
SECRET_KEY=exemplo_troque_por_uma_chave_longa_com_mais_de_32_caracteres
AUTH_COOKIE_NAME=helpwebhealth_session
# Em producao/Shard, mantenha true. Em teste local HTTP, use false.
AUTH_COOKIE_SECURE=false
# Local HTTP pode usar lax. Em frontend/backend separados por subdominio HTTPS, use none.
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# Usuario administrador criado automaticamente na primeira execucao.
ADMIN_EMAIL=admin.exemplo@helpwebhealth.local
ADMIN_PASSWORD=troque_por_uma_senha_forte_com_12_ou_mais_caracteres

# URLs exatas do frontend autorizadas a acessar a API.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://seu-front.shardweb.app
ENABLE_API_DOCS=false
ENABLE_DB_HEALTH_ENDPOINT=false
API_DOCS_USERNAME=admin
API_DOCS_PASSWORD=

# Logs. Use LOG_FORMAT=json se quiser enviar para monitoramento externo.
LOG_LEVEL=INFO
LOG_FORMAT=text
ALLOW_LOG_VERIFICATION_CODES=false

# Email para codigos de verificacao.
# Exemplo com Gmail usando senha de app. Use dados reais apenas no painel da hospedagem ou no .env local.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=suporte.helpwebhealth@gmail.com
SMTP_PASSWORD=senha_de_app_do_gmail_sem_espacos
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=30
MAIL_FROM=suporte.helpwebhealth@gmail.com
MAIL_FROM_NAME=HelpWeb Health
REPLY_TO_EMAIL=suporte.helpwebhealth@gmail.com
EMAIL_CODE_EXPIRE_MINUTES=15
VERIFICATION_RESEND_COOLDOWN_SECONDS=300
ACCOUNT_RECOVERY_MIN_RESPONSE_SECONDS=1.2
ACCOUNT_RECOVERY_WINDOW_SECONDS=900
ACCOUNT_RECOVERY_MAX_REQUESTS_PER_EMAIL=5
ACCOUNT_RECOVERY_MAX_REQUESTS_PER_IP=20

# Rate limit global por IP + usuario/token.
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=240
RATE_LIMIT_SENSITIVE_MAX_REQUESTS=40
MAX_TICKET_IMAGE_TICKETS_PER_USER_DAY=12

# Por seguranca, ignore headers de proxy por padrao.
# Use 1 somente se a hospedagem confirmar X-Forwarded-For confiavel.
TRUSTED_PROXY_HOPS=0

# Inicializacao da API.
RUN_MIGRATIONS_ON_STARTUP=true
STARTUP_LOCK_PATH=
STARTUP_LOCK_TIMEOUT_SECONDS=120
STARTUP_LOCK_STALE_SECONDS=300
